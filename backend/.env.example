# ============================================================
# Ethara SAPSM — Backend environment variables (example)
# Copy to `.env` and fill in real values. Never commit `.env`.
# ============================================================

# --- Application ---
ENVIRONMENT=development
APP_NAME=Ethara SAPSM
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- CORS ---
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000

# --- Database (primary app connection) ---
# For local dev with Docker Postgres:
#   postgresql+asyncpg://postgres:postgres@localhost:5432/ethara
# For Neon (use the POOLED connection host — the one with -pooler):
#   postgresql+asyncpg://<user>:<pw>@ep-xxx-pooler.<region>.neon.tech/<db>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ethara

# Sync URL for Alembic migrations. Same DB, different driver.
#   postgresql+psycopg2://postgres:postgres@localhost:5432/ethara
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/ethara

# --- AI reader role (SELECT-only, for NL-to-SQL) ---
# Created via docs/neon_setup.md.
AI_READER_DATABASE_URL=postgresql+asyncpg://ai_reader:changeme@localhost:5432/ethara

# --- JWT auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_HEX_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Gemini (Google AI Studio) ---
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Seed data ---
# small (500) | full (5000)
SEED_SCALE=full
SEED_DEMO_PASSWORD=demo1234
